<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Service Unavailable</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@700&display=swap" rel="stylesheet" />
  <style>
    body {
      background: #0a0a0f;
      color: #e0e0ec;
      font-family: 'JetBrains Mono', monospace;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      text-align: center;
    }
    .err { max-width: 500px; padding: 2rem; }
    h1 { font-family: 'Syne', sans-serif; font-size: 4rem; color: #ff5555; margin-bottom: 1rem; }
    p { font-size: .9rem; color: #7a7a8e; line-height: 1.6; }
    code { color: #00e5a0; }
  </style>
</head>
<body>
  <div class="err">
    <h1>503</h1>
    <p><%= message %></p>
    <p style="margin-top:1rem">Check that <code>portfolio-api</code> is running on port <code>8000</code>.</p>
  </div>
</body>
</html>
