<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= data.profile.name %> — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0a0a0f;
      --bg-card: #111118;
      --bg-card-hover: #16161f;
      --surface: #1a1a25;
      --border: #2a2a3a;
      --border-glow: #00e5a0;
      --text: #e0e0ec;
      --text-dim: #7a7a8e;
      --text-bright: #ffffff;
      --accent: #00e5a0;
      --accent2: #00b4d8;
      --accent3: #8b5cf6;
      --danger: #ff5555;
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Syne', sans-serif;
      --body: 'Space Grotesk', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--body);
      line-height: 1.65;
      overflow-x: hidden;
    }

    /* ── Animated grid background ────────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,229,160,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,160,.03) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(ellipse at 30% 20%, rgba(0,229,160,.06) 0%, transparent 50%),
                  radial-gradient(ellipse at 70% 80%, rgba(139,92,246,.05) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
      animation: aurora 20s ease-in-out infinite alternate;
    }

    @keyframes aurora {
      0%   { transform: translate(0, 0) rotate(0deg); }
      100% { transform: translate(-5%, 3%) rotate(3deg); }
    }

    section, header, footer { position: relative; z-index: 1; }

    /* ── Navigation ──────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      backdrop-filter: blur(20px) saturate(1.4);
      background: rgba(10,10,15,.75);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
    }

    nav .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }

    nav .logo {
      font-family: var(--mono);
      font-weight: 700;
      font-size: .95rem;
      color: var(--accent);
      letter-spacing: .5px;
    }

    nav .logo .blink {
      animation: blink 1s step-end infinite;
    }

    @keyframes blink { 50% { opacity: 0; } }

    nav .links { display: flex; gap: 2rem; }

    nav .links a {
      font-family: var(--mono);
      font-size: .75rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-dim);
      text-decoration: none;
      transition: color .3s;
    }

    nav .links a:hover { color: var(--accent); }

    /* ── Hero ────────────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 6rem 2rem 4rem;
    }

    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-tag {
      font-family: var(--mono);
      font-size: .8rem;
      color: var(--accent);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeUp .8s .2s forwards;
    }

    .hero-tag::before {
      content: '▸ ';
      color: var(--accent3);
    }

    .hero h1 {
      font-family: var(--sans);
      font-size: clamp(3rem, 8vw, 6.5rem);
      font-weight: 800;
      line-height: 1;
      color: var(--text-bright);
      margin-bottom: 1rem;
      opacity: 0;
      animation: fadeUp .8s .4s forwards;
    }

    .hero h1 span {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      font-family: var(--mono);
      font-size: 1.1rem;
      color: var(--text-dim);
      max-width: 700px;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeUp .8s .6s forwards;
    }

    .hero-stats {
      display: flex;
      gap: 3rem;
      flex-wrap: wrap;
      opacity: 0;
      animation: fadeUp .8s .8s forwards;
    }

    .stat {
      text-align: left;
    }

    .stat-value {
      font-family: var(--sans);
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
    }

    .stat-label {
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: .25rem;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Section Headers ─────────────────────────────────────────── */
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 6rem 2rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .section-header h2 {
      font-family: var(--sans);
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--text-bright);
    }

    .section-header .line {
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--border), transparent);
    }

    .section-header .num {
      font-family: var(--mono);
      font-size: .8rem;
      color: var(--accent);
    }

    /* ── Skills Grid ─────────────────────────────────────────────── */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    }

    .skill-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      transition: all .4s cubic-bezier(.165,.84,.44,1);
      position: relative;
      overflow: hidden;
    }

    .skill-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3));
      opacity: 0;
      transition: opacity .4s;
    }

    .skill-card:hover {
      border-color: var(--accent);
      background: var(--bg-card-hover);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,229,160,.08);
    }

    .skill-card:hover::before { opacity: 1; }

    .skill-category {
      font-family: var(--mono);
      font-size: .75rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 1rem;
    }

    .skill-tags {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
    }

    .skill-tag {
      font-family: var(--mono);
      font-size: .75rem;
      padding: .35rem .75rem;
      background: rgba(0,229,160,.06);
      border: 1px solid rgba(0,229,160,.15);
      border-radius: 6px;
      color: var(--text);
      transition: all .3s;
    }

    .skill-card:hover .skill-tag {
      border-color: rgba(0,229,160,.3);
      background: rgba(0,229,160,.1);
    }

    /* ── Experience Timeline ─────────────────────────────────────── */
    .timeline {
      position: relative;
      padding-left: 3rem;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 7px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, var(--accent), var(--accent3), transparent);
    }

    .timeline-item {
      position: relative;
      margin-bottom: 3rem;
    }

    .timeline-dot {
      position: absolute;
      left: -3rem;
      top: .5rem;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--bg);
      border: 3px solid var(--accent);
      box-shadow: 0 0 20px rgba(0,229,160,.3);
      z-index: 2;
    }

    .timeline-item:nth-child(2) .timeline-dot {
      border-color: var(--accent3);
      box-shadow: 0 0 20px rgba(139,92,246,.3);
    }

    .timeline-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      flex-wrap: wrap;
      gap: .5rem;
      margin-bottom: .5rem;
    }

    .timeline-title {
      font-family: var(--sans);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--text-bright);
    }

    .timeline-company {
      font-family: var(--mono);
      font-size: .85rem;
      color: var(--accent);
    }

    .timeline-meta {
      font-family: var(--mono);
      font-size: .75rem;
      color: var(--text-dim);
      margin-bottom: 1rem;
    }

    .timeline-highlights {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .75rem;
    }

    .timeline-highlights li {
      position: relative;
      padding-left: 1.5rem;
      font-size: .92rem;
      color: var(--text);
      line-height: 1.6;
    }

    .timeline-highlights li::before {
      content: '▹';
      position: absolute;
      left: 0;
      color: var(--accent);
      font-size: 1rem;
    }

    /* ── Certifications ──────────────────────────────────────────── */
    .certs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem;
    }

    .cert-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      transition: all .4s cubic-bezier(.165,.84,.44,1);
    }

    .cert-card:hover {
      transform: translateY(-3px);
      border-color: var(--accent2);
      box-shadow: 0 8px 30px rgba(0,180,216,.1);
    }

    .cert-badge {
      width: 50px;
      height: 50px;
      border-radius: 10px;
      background: linear-gradient(135deg, rgba(0,229,160,.15), rgba(0,180,216,.15));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: .7rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: .5px;
      flex-shrink: 0;
      border: 1px solid rgba(0,229,160,.2);
    }

    .cert-name {
      font-size: .9rem;
      color: var(--text);
      line-height: 1.4;
    }

    /* ── Projects ────────────────────────────────────────────────── */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 1.5rem;
    }

    .project-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      transition: all .4s cubic-bezier(.165,.84,.44,1);
      position: relative;
      overflow: hidden;
    }

    .project-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .4s;
    }

    .project-card:hover {
      transform: translateY(-4px);
      border-color: var(--accent);
      box-shadow: 0 12px 40px rgba(0,229,160,.08);
    }

    .project-card:hover::after { transform: scaleX(1); }

    .project-name {
      font-family: var(--sans);
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--text-bright);
      margin-bottom: .75rem;
    }

    .project-desc {
      font-size: .9rem;
      color: var(--text-dim);
      line-height: 1.6;
      margin-bottom: 1.25rem;
    }

    .project-tech {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
    }

    .project-tech span {
      font-family: var(--mono);
      font-size: .7rem;
      padding: .3rem .65rem;
      background: rgba(139,92,246,.1);
      border: 1px solid rgba(139,92,246,.2);
      border-radius: 5px;
      color: var(--accent3);
    }

    /* ── Architecture Section ────────────────────────────────────── */
    .arch-container {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
    }

    .arch-container::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2), var(--accent3));
    }

    .arch-title {
      font-family: var(--sans);
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text-bright);
      margin-bottom: 1.5rem;
    }

    .arch-diagram {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .arch-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem 2rem;
      text-align: center;
      min-width: 180px;
      transition: all .3s;
    }

    .arch-box:hover {
      border-color: var(--accent);
      box-shadow: 0 4px 20px rgba(0,229,160,.1);
    }

    .arch-box-label {
      font-family: var(--mono);
      font-size: .65rem;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--accent);
      margin-bottom: .5rem;
    }

    .arch-box-tech {
      font-family: var(--sans);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-bright);
    }

    .arch-box-detail {
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--text-dim);
      margin-top: .25rem;
    }

    .arch-arrow {
      font-size: 1.5rem;
      color: var(--accent);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: .4; }
      50% { opacity: 1; }
    }

    .arch-steps {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }

    .arch-step {
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      padding: 1rem;
      background: var(--surface);
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .arch-step-num {
      font-family: var(--mono);
      font-size: .75rem;
      font-weight: 700;
      color: var(--accent);
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--accent);
      border-radius: 6px;
    }

    .arch-step-text {
      font-size: .85rem;
      color: var(--text);
      line-height: 1.5;
    }

    .arch-step-text strong {
      color: var(--accent);
      font-weight: 600;
    }

    /* ── Footer ──────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 3rem 2rem;
      text-align: center;
    }

    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .footer-links {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-bottom: 1.5rem;
    }

    .footer-links a {
      font-family: var(--mono);
      font-size: .8rem;
      color: var(--text-dim);
      text-decoration: none;
      transition: color .3s;
    }

    .footer-links a:hover { color: var(--accent); }

    .footer-note {
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--text-dim);
    }

    .footer-note .highlight { color: var(--accent); }

    /* ── Responsive ──────────────────────────────────────────────── */
    @media (max-width: 768px) {
      nav .links { gap: 1rem; }
      nav .links a { font-size: .65rem; }
      .hero h1 { font-size: 2.5rem; }
      .hero-stats { gap: 1.5rem; }
      .timeline { padding-left: 2rem; }
      .timeline::before { left: 5px; }
      .timeline-dot { left: -2rem; width: 12px; height: 12px; }
      .arch-diagram { flex-direction: column; }
      .arch-arrow { transform: rotate(90deg); }
      .projects-grid { grid-template-columns: 1fr; }
    }

    /* ── Scroll reveal ───────────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all .7s cubic-bezier(.165,.84,.44,1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>

  <!-- ── Navigation ──────────────────────────────────────────────── -->
  <nav>
    <div class="nav-inner">
      <div class="logo">altair<span class="blink">_</span>yedressov</div>
      <div class="links">
        <a href="#skills">Skills</a>
        <a href="#experience">Experience</a>
        <a href="#certs">Certs</a>
        <a href="#projects">Projects</a>
        <a href="#architecture">Architecture</a>
      </div>
    </div>
  </nav>

  <!-- ── Hero ────────────────────────────────────────────────────── -->
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-tag"><%= data.profile.title %></div>
      <h1><%= data.profile.name.split(' ')[0] %> <span><%= data.profile.name.split(' ')[1] %></span></h1>
      <p class="hero-subtitle"><%= data.profile.summary %></p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-value">5+</div>
          <div class="stat-label">Years Experience</div>
        </div>
        <div class="stat">
          <div class="stat-value">10+</div>
          <div class="stat-label">EKS Clusters</div>
        </div>
        <div class="stat">
          <div class="stat-value">20+</div>
          <div class="stat-label">Microservices</div>
        </div>
        <div class="stat">
          <div class="stat-value">40+</div>
          <div class="stat-label">Engineers Supported</div>
        </div>
      </div>
    </div>
  </header>

  <!-- ── Skills ──────────────────────────────────────────────────── -->
  <section class="section reveal" id="skills">
    <div class="section-header">
      <span class="num">01</span>
      <h2>Skills & Tools</h2>
      <div class="line"></div>
    </div>
    <div class="skills-grid">
      <% data.skills.forEach(function(skill) { %>
        <div class="skill-card">
          <div class="skill-category"><%= skill.category %></div>
          <div class="skill-tags">
            <% skill.items.forEach(function(item) { %>
              <span class="skill-tag"><%= item %></span>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- ── Experience ──────────────────────────────────────────────── -->
  <section class="section reveal" id="experience">
    <div class="section-header">
      <span class="num">02</span>
      <h2>Experience</h2>
      <div class="line"></div>
    </div>
    <div class="timeline">
      <% data.experience.forEach(function(exp) { %>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-header">
            <div>
              <div class="timeline-title"><%= exp.title %></div>
              <div class="timeline-company"><%= exp.company %></div>
            </div>
          </div>
          <div class="timeline-meta"><%= exp.period %> · <%= exp.location %></div>
          <ul class="timeline-highlights">
            <% exp.highlights.forEach(function(h) { %>
              <li><%= h %></li>
            <% }); %>
          </ul>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- ── Certifications ──────────────────────────────────────────── -->
  <section class="section reveal" id="certs">
    <div class="section-header">
      <span class="num">03</span>
      <h2>Certifications</h2>
      <div class="line"></div>
    </div>
    <div class="certs-grid">
      <% data.certifications.forEach(function(cert) { %>
        <div class="cert-card">
          <div class="cert-badge"><%= cert.abbrev %></div>
          <div class="cert-name"><%= cert.name %></div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- ── Projects ────────────────────────────────────────────────── -->
  <section class="section reveal" id="projects">
    <div class="section-header">
      <span class="num">04</span>
      <h2>Projects</h2>
      <div class="line"></div>
    </div>
    <div class="projects-grid">
      <% data.projects.forEach(function(proj) { %>
        <div class="project-card">
          <div class="project-name"><%= proj.name %></div>
          <div class="project-desc"><%= proj.description %></div>
          <div class="project-tech">
            <% proj.tech.forEach(function(t) { %>
              <span><%= t %></span>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- ── Architecture ────────────────────────────────────────────── -->
  <section class="section reveal" id="architecture">
    <div class="section-header">
      <span class="num">05</span>
      <h2>How This App Works</h2>
      <div class="line"></div>
    </div>
    <div class="arch-container">
      <div class="arch-title">Two-Tier Architecture on AWS EKS</div>
      <div class="arch-diagram">
        <div class="arch-box">
          <div class="arch-box-label">User</div>
          <div class="arch-box-tech">Browser</div>
          <div class="arch-box-detail">HTTPS request</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-box" style="border-color: var(--accent2);">
          <div class="arch-box-label">Frontend</div>
          <div class="arch-box-tech">Node.js + Express</div>
          <div class="arch-box-detail">Port 3000 · EJS templates</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-box" style="border-color: var(--accent3);">
          <div class="arch-box-label">Backend API</div>
          <div class="arch-box-tech">Python + FastAPI</div>
          <div class="arch-box-detail">Port 8000 · /api/*</div>
        </div>
      </div>
      <ul class="arch-steps">
        <li class="arch-step">
          <span class="arch-step-num">1</span>
          <span class="arch-step-text"><strong>Frontend & Backend</strong> are separate Docker containers, each with its own Dockerfile</span>
        </li>
        <li class="arch-step">
          <span class="arch-step-num">2</span>
          <span class="arch-step-text"><strong>Images pushed</strong> to Amazon ECR (Elastic Container Registry)</span>
        </li>
        <li class="arch-step">
          <span class="arch-step-num">3</span>
          <span class="arch-step-text"><strong>Kubernetes Deployments</strong> run pods for each tier on EKS with health checks</span>
        </li>
        <li class="arch-step">
          <span class="arch-step-num">4</span>
          <span class="arch-step-text"><strong>ClusterIP Service</strong> exposes the backend internally; frontend connects via env var</span>
        </li>
        <li class="arch-step">
          <span class="arch-step-num">5</span>
          <span class="arch-step-text"><strong>LoadBalancer Service</strong> exposes the frontend to the internet via AWS ALB</span>
        </li>
        <li class="arch-step">
          <span class="arch-step-num">6</span>
          <span class="arch-step-text"><strong>Built with Claude AI</strong> — AI-assisted development using Claude & Claude Code</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ── Footer ──────────────────────────────────────────────────── -->
  <footer>
    <div class="footer-inner">
      <div class="footer-links">
        <a href="mailto:<%= data.profile.email %>"><%= data.profile.email %></a>
        <a href="https://<%= data.profile.linkedin %>" target="_blank">LinkedIn</a>
        <a href="https://<%= data.profile.github %>" target="_blank">GitHub</a>
      </div>
      <p class="footer-note">
        Two-tier app: <span class="highlight">Node.js</span> frontend ↔ <span class="highlight">Python FastAPI</span> backend · Deployed on <span class="highlight">AWS EKS</span> · Built with <span class="highlight">Claude AI</span>
      </p>
    </div>
  </footer>

  <!-- ── Scroll Reveal ───────────────────────────────────────────── -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("visible");
          }
        });
      },
      { threshold: 0.1 }
    );
    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
  </script>

</body>
</html>
