# ─── SMTP Configuration ───────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Recipient ────────────────────────────────────────────────
RECIPIENT_EMAIL=contact@yedressov.com

# ─── Server ───────────────────────────────────────────────────
BACKEND_PORT=5000
FLASK_DEBUG=false

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yedressov.com

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT=5
RATE_WINDOW_MINUTES=15
